# autoria-mcp configuration. Copy to `.env` and fill in your values.
# `.env` is gitignored — never commit real credentials.

# --- Credentials -----------------------------------------------------------
# Personal AUTO.RIA API key. Get one at https://developers.ria.com
# Sent as the `api_key` query param on every request. NEVER log or commit it.
AUTORIA_API_KEY=

# User id, required only by the paid POST endpoints (sent as `user_id`).
# Leave blank if you only use the freemium GET endpoints.
AUTORIA_USER_ID=

# --- Transport -------------------------------------------------------------
# "stdio" (default) or "http" (streamable-HTTP). Also settable via --transport.
AUTORIA_TRANSPORT=stdio
# HTTP transport bind address (ignored for stdio):
AUTORIA_HOST=127.0.0.1
AUTORIA_PORT=8000

# --- API / caching ---------------------------------------------------------
# Only the production host is documented; override only if you know why.
AUTORIA_BASE_URL=https://developers.ria.com
# Dictionary cache location and TTL (seconds). Default TTL = 7 days.
# AUTORIA_CACHE_DIR=./cache
AUTORIA_CACHE_TTL=604800

# --- Retries ---------------------------------------------------------------
# Bounded retry with exponential backoff + full jitter on 429 / 5xx only.
AUTORIA_MAX_RETRIES=3
AUTORIA_BACKOFF_BASE=0.5
AUTORIA_BACKOFF_CAP=8.0

# --- Quota accounting (warn-only) ------------------------------------------
# RIA exposes no rate-limit headers; usage is tracked locally and a warning is
# logged near these limits. Requests are never blocked. Free pkg ~30/hr, 1000/mo.
AUTORIA_QUOTA_HOURLY_LIMIT=30
AUTORIA_QUOTA_MONTHLY_LIMIT=1000
AUTORIA_QUOTA_WARN_RATIO=0.9

# --- Logging ---------------------------------------------------------------
AUTORIA_LOG_LEVEL=INFO
